datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["pinned-queries"]
}

model Cart {
  id       String   @id @default(cuid())
  products  Product[]
}

model Product {
  id       String   @id @default(cuid())
  name     String
  price    Float
  carts    Cart[]
}